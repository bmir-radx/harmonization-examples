[
  {
    "sources": [
      "satisfaction"
    ],
    "target": "satisfaction_label",
    "operations": [
      {
        "operation": "cast",
        "source": "integer",
        "target": "text"
      },
      {
        "operation": "enum_to_enum",
        "mapping": {
          "1": "very_dissatisfied",
          "2": "dissatisfied",
          "3": "neutral",
          "4": "satisfied",
          "5": "very_satisfied"
        },
        "strict": false,
        "default": "unknown"
      }
    ],
    "metadata": {
      "rationale": "Likert int -> label. Cast to text so the string keys survive JSON round-trip; lenient with default='unknown' since out-of-range codes shouldn't crash a survey import."
    }
  },
  {
    "sources": [
